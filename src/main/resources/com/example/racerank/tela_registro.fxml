<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.racerank.controller.RegistroDaVoltaController"
      spacing="20" style="-fx-padding: 20;">

    <!-- Lado Esquerdo: Formulário -->
    <VBox spacing="15" prefWidth="300">
        <Label text="Registro de Voltas" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <Label text="Piloto:" />
        <ComboBox fx:id="comboPiloto" maxWidth="Infinity" />

        <Label text="Pista:" />
        <ComboBox fx:id="comboPista" maxWidth="Infinity" />

        <Label text="Tempo da volta (ms):" />
        <TextField fx:id="campoTempo" promptText="00000" />

        <Button text="Registrar Volta" onAction="#salvarVolta" maxWidth="Infinity"
                style="-fx-background-color: #0D6EFD; -fx-text-fill: white;" />
    </VBox>

    <!-- Lado Direito: Tabela -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label text="Últimas Voltas Registradas" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <!--tabela com os dados-->
        <TableView fx:id="tabelaVoltas" VBox.vgrow="ALWAYS"
                   style="-fx-font-size: 14px; -fx-border-color: #DEE2E6; -fx-border-radius: 5;">
            <columns>
                <TableColumn fx:id="colPiloto" prefWidth="250.0" text="Piloto" />
                <TableColumn fx:id="colPista" prefWidth="250.0" text="Pista" />
                <TableColumn fx:id="colTempo" prefWidth="200.0" text="Tempo (ms)" />
                <TableColumn fx:id="colData" prefWidth="200.0" text="Data de Criação" />
            </columns>

            <!-- preenchendo o espaço vazio-->
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <Button text="Excluir" onAction="#excluirVoltaSelecionada"
                style="-fx-background-color: #DC3545; -fx-text-fill: white;" />
    </VBox>

</HBox>