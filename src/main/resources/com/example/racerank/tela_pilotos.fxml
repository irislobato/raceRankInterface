<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.racerank.controller.PilotoController">

    <!--caeçalho-->
    <HBox alignment="CENTER_LEFT">
        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Pilotos" />

        <!--Region HBox.hgrow="ALWAYS" empurra o botão para a direita-->
        <Region HBox.hgrow="ALWAYS" />

        <!--botão adicionar um novo piloto-->
        <Button onAction="#novoPiloto" style="-fx-background-color: #0D6EFD; -fx-text-fill: WHITE; -fx-font-weight: bold;
        -fx-padding: 8 15 8 15; -fx-background-radius: 5;" text="+ Novo Piloto" />
    </HBox>

    <!--barra de pesquisa-->
    <HBox>
        <TextField fx:id="campoPesquisa" prefWidth="300.0" promptText="Buscar piloto..." style="-fx-padding: 8;
        -fx-background-radius: 5; -fx-border-color: #DEE2E6; -fx-border-radius: 5;" />
    </HBox>

    <!--tabela com os dados-->
    <TableView fx:id="tabelaPilotos" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px; -fx-border-color: #DEE2E6;
    -fx-border-radius: 5;">
        <columns>
            <TableColumn fx:id="colunaId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colunaNome" prefWidth="300.0" text="Nome" />
            <TableColumn fx:id="colunaEquipe" prefWidth="250.0" text="Equipe" />
            <TableColumn fx:id="colunaData" prefWidth="200.0" text="Data de Criação" />
        </columns>

        <!-- preenchendo o espaço vazio-->
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
        <Button text="Editar" onAction="#editarPiloto"  style="-fx-background-color: #0D6EFD; -fx-text-fill: WHITE;
        -fx-font-weight: bold; -fx-background-radius: 5;" />
        <Button text="Excluir" onAction="#deletarPiloto" style="-fx-background-color: #0D6EFD; -fx-text-fill: WHITE;
        -fx-font-weight: bold; -fx-background-radius: 5;" />
    </HBox>

</VBox>